<div class="auth-wrapper">
  <div class="card">
    <div class="auth-header">
      <h1>Welcome Back</h1>
      <p>Log in to access your dog tag permits</p>
    </div>

    <%= form_with url: login_path, local: true, class: "auth-form" do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email Address" %>
        <%= f.email_field :email, class: "form-control", placeholder: "you@example.com", required: true, autofocus: true %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, class: "form-control", placeholder: "••••••••", required: true %>
      </div>

      <div class="form-actions">
        <%= f.submit "Log In", class: "btn btn-primary" %>
      </div>
    <% end %>

    <div class="form-footer">
      Don't have an account? <%= link_to "Sign up here", signup_path %>
    </div>
  </div>
</div>
